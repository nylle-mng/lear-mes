# Node-RED / Node.js Backend Environment Variables
# Copy this file to .env and fill in your values

# ─── MQTT Broker (HiveMQ Cloud or local Mosquitto) ───────────────────────────
MQTT_BROKER=mqtts://your-cluster.hivemq.cloud
MQTT_PORT=8883
MQTT_USER=your_hivemq_username
MQTT_PASS=your_hivemq_password
# For local Mosquitto: MQTT_BROKER=mqtt://localhost, MQTT_PORT=1883

# ─── PostgreSQL Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/lear_mes
# Render: copy connection string from Render PostgreSQL dashboard
# Supabase: copy from Supabase project settings → Database → Connection string

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
# React dashboard WebSocket/API URL (set VITE_API_URL in frontend to match)

# ─── MES Config ──────────────────────────────────────────────────────────────
PLANT_ID=plant1
SHIFT_DURATION_HOURS=8
OEE_SNAPSHOT_INTERVAL_SEC=60
